{
  "name": "@editable-ui/adapter-sqlite",
  "version": "0.0.5",
  "description": "SQLite adapter for editable-ui",
  "repository": { "type": "git", "url": "git+https://github.com/hanifhadyan/editable-ui.git" },
  "homepage": "https://github.com/hanifhadyan/editable-ui#readme",
  "bugs": { "url": "https://github.com/hanifhadyan/editable-ui/issues" },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@editable-ui/core": "workspace:*",
    "better-sqlite3": "^9.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
